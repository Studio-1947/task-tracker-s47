# ─────────────────────────────────────────────────────────────
# Root env — copy to .env for local development.
# In staging/prod these are injected by the platform / secrets manager.
# ─────────────────────────────────────────────────────────────

# --- Postgres (used by docker-compose + the API) ---
POSTGRES_USER=tasktracker
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=task_tracker
POSTGRES_PORT=5432

# Full connection string the API consumes.
# Host is "localhost" when running the API on the host against docker Postgres,
# and "postgres" (the compose service name) when the API runs inside compose.
DATABASE_URL=postgresql://tasktracker:change-me-in-prod@localhost:5432/task_tracker

# --- API ---
NODE_ENV=development
API_PORT=3000

# JWT secrets — generate strong random values in prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookie/CORS
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:5173

# Seed admin (used by db:seed) — change before first prod seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Admin

# Second seed admin (used by db:seed)
SEED_ADMIN2_EMAIL=admin2@example.com
SEED_ADMIN2_PASSWORD=admin2_12345
SEED_ADMIN2_NAME=Admin 2

# --- Super-dev (hidden developer console at /super-dev) ---
# Leave ALL THREE blank to keep the console fully disabled (routes 404). Setting them
# enables it. This identity lives ONLY here — it is never a row in the users table, so
# admins/members cannot see or reach it anywhere in the product.
#   SUPERDEV_JWT_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SUPERDEV_EMAIL=
SUPERDEV_PASSWORD=
SUPERDEV_JWT_SECRET=
SUPERDEV_JWT_TTL=8h
# Optional IP/CIDR allowlist — requests from other IPs get 404 (as if it doesn't exist).
# Comma-separated, e.g. "203.0.113.4, 10.0.0.0/8". Blank = no IP restriction.
# (Relies on your edge proxy setting X-Forwarded-For; login is also rate-limited: 5 fails / 15 min → lockout.)
SUPERDEV_ALLOWED_IPS=

# --- Web (Vite) ---
VITE_API_URL=http://localhost:3000

# File uploads (avatars, task attachments); relative paths resolve against apps/api cwd
UPLOAD_DIR=uploads
