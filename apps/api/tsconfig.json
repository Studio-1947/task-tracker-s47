{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "types": ["node", "multer"],
    "noUncheckedIndexedAccess": false
    // NOTE: do NOT enable "incremental" here. `nest build` sets deleteOutDir=true;
    // with incremental, tsc trusts .tsbuildinfo and re-emits only changed files
    // after the dir is wiped, leaving a partial dist (missing main.js).
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
